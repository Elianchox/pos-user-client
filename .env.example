# URL del backend POS (incluye /api/mobile)
# EXPO_PUBLIC_API_URL=https://pos.eliancho.dev/api/mobile
EXPO_PUBLIC_API_URL=https://<tunnel-host>/api/mobile

# Hosts permitidos para validar QR deep links (separados por coma)
# EXPO_PUBLIC_QR_ALLOWED_HOSTS=pos.eliancho.dev,192.168.1.17:3000
EXPO_PUBLIC_QR_ALLOWED_HOSTS=<tunnel-host>,pos.eliancho.dev
